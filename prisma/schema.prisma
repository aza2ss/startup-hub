datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  emailVerified  DateTime?
  image          String?
  avatar         String?
  role           String           @default("Участник")
  bio            String           @default("")
  skills         String           @default("") // Comma-separated list of skills
  createdAt      DateTime         @default(now())
  ownedProjects  Project[]        @relation("ProjectOwner")
  memberProjects Project[]        @relation("ProjectMembers")
  updates        ProgressUpdate[]
  comments       Comment[]
  accounts       Account[]
  sessions       Session[]
  projectFollows ProjectFollow[]
  savedProjects  SavedProject[]
  followers      UserFollow[]     @relation("UserFollowing")
  following      UserFollow[]     @relation("UserFollower")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id              String           @id
  title           String
  description     String
  longDescription String
  status          String           // idea, mvp, growth, scaling
  category        String
  tags            String           // Comma-separated tags
  technologies    String           // Comma-separated technologies
  progress        Int              @default(0)
  ownerId         String
  owner           User             @relation("ProjectOwner", fields: [ownerId], references: [id])
  teamMembers     User[]           @relation("ProjectMembers")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  links           ProjectLink[]
  openPositions   TeamRequest[]
  progressLog     ProgressUpdate[]
  comments        Comment[]
  follows         ProjectFollow[]
  savedBy         SavedProject[]
}

model ProjectLink {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
}

model ProgressUpdate {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  type      String   // milestone, update, launch, team
  createdAt DateTime @default(now())
}

model TeamRequest {
  id           String            @id
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role         String
  description  String
  skills       String            // Comma-separated skills
  createdAt    DateTime          @default(now())
  applications TeamApplication[]
}

model TeamApplication {
  id            String      @id @default(uuid())
  teamRequestId String
  teamRequest   TeamRequest @relation(fields: [teamRequestId], references: [id], onDelete: Cascade)
  name          String
  contact       String
  message       String
  createdAt     DateTime    @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model ProjectFollow {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model SavedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

